{
  "name": "lena-ts",
  "version": "0.1.21",
  "description": "Library for image processing zero dependencies",
  "keywords": [
    "filter",
    "image manipulation",
    "image processing"
  ],
  "homepage": "https://github.com/ahaoboy/lena-ts",
  "bugs": {
    "url": "https://github.com/ahaoboy/lena-ts/issues"
  },
  "license": "MIT",
  "author": "ahaoboy",
  "repository": {
    "type": "git",
    "url": "https://github.com/ahaoboy/lena-ts.git"
  },
  "files": [
    "esm",
    "cjs",
    "src"
  ],
  "sideEffects": false,
  "main": "./cjs/index.js",
  "module": "./esm/index.js",
  "types": "./esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.js",
      "require": "./cjs/index.js",
      "default": "./cjs/index.js"
    }
  },
  "scripts": {
    "pre-check": "oxfmt && oxlint --fix",
    "build:cjs": "tsc --outDir cjs --declaration false --module commonjs",
    "build:esm": "tsc --outDir esm --module esnext",
    "build": "npm run build:cjs && npm run build:esm",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "dev": "cd web && npm run dev",
    "build:web": "cd web && npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "25.9.3",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "globals": "^17.6.0",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "typescript": "6.0.3",
    "vite": "8.0.12"
  }
}
